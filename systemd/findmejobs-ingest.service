[Unit]
Description=FindMeJobs ingest run
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=findmejobs
Group=findmejobs
WorkingDirectory=/opt/findmejobs
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/findmejobs/.venv/bin/findmejobs ingest --app-config-path /etc/findmejobs/app.toml --profile-path /etc/findmejobs/profile.yaml --sources-path /etc/findmejobs/sources.yaml

[Install]
WantedBy=multi-user.target
